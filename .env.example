# ─────────────────────────────────────────────────────────────
# Jump Start — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# The headless runner loads .env automatically via dotenv.
# ─────────────────────────────────────────────────────────────

# ── LiteLLM Proxy ────────────────────────────────────────────
# Jump Start uses LiteLLM as a unified gateway to 100+ LLM
# providers (OpenAI, Anthropic, Google, etc.) via an
# OpenAI-compatible API.
#
# Start the LiteLLM proxy first:
#   pip install litellm
#   litellm --model gpt-4o
#
# See https://docs.litellm.ai for full configuration.

# URL of your LiteLLM proxy server (default: http://localhost:4000)
LITELLM_BASE_URL=http://localhost:4000

# API key for authenticating with the LiteLLM proxy.
# Required when the proxy is configured with key-based auth.
LITELLM_API_KEY=

# ── Fallback API Key ─────────────────────────────────────────
# If LITELLM_API_KEY is not set, the provider falls back to
# OPENAI_API_KEY. Useful when running LiteLLM without auth
# but still needing a key for direct OpenAI calls.
OPENAI_API_KEY=

# ── Debugging ─────────────────────────────────────────────────
# Set to any truthy value to enable verbose error stack traces
# in the headless runner.
# DEBUG=1
